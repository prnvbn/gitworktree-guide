{
  "name": "git-worktree-simple-guide",
  "version": "1.0.0",
  "private": true,
  "description": "A short, visual guide to Git worktrees.",
  "scripts": {
    "build": "npm run build:css && node ./scripts/prepare-dist.mjs",
    "build:css": "tailwindcss -i ./src/input.css -o ./styles.css --minify",
    "dev": "tailwindcss -i ./src/input.css -o ./styles.css --watch",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17",
    "wrangler": "4.110.0"
  }
}
